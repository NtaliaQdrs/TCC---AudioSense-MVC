//- MENU PRINCIPAL CORRIGIDO
header.top-bar
  .top-bar-content
    .logo
      a(href="/" aria-label="AudioSense - Página Inicial")
        img(src="/images/audiosense.png" alt="")

    //- Botão de categorias mobile
    button#categoryToggle.category-toggle(
      aria-label="Abrir menu de categorias" 
      aria-haspopup="true" 
      aria-expanded="false"
      aria-controls="categoryDropdown"
    )
      i.bi.bi-grid-3x3-gap-fill(aria-hidden="true")

    //- Contêiner para as categorias do sub-menu (visível apenas no mobile)
    #categoryDropdown.category-dropdown
      .category-links
        a.dropdown-item(href="/") Início
        a.dropdown-item(href="/deficiencia-visual") Deficiência visual
        a.dropdown-item(href="/audiodescricao") Audiodescrição
        a.dropdown-item(href="/entretenimento") Entretenimento
        a.dropdown-item(href="/forum") Fórum
        a.dropdown-item(href="/biblioteca") Biblioteca

    nav.menu-links(aria-label="Menu Principal")
      a(href="/") Início
      a(href="#") Configurações
      a(href="#") Sobre nós

    .menu-right
      .search-box
        i.bi.bi-search(aria-hidden="true")
        input(type="text" placeholder="Pesquise..." aria-label="Pesquisar conteúdo no AudioSense")

      //- Perfil
      .profile-menu
        button#profileBtn.profile-button(aria-haspopup="true" 
                                        aria-expanded="false" 
                                        aria-controls="profileDropdown" 
                                        aria-label="Menu do perfil do usuário")
          span Perfil 
          i#perfil-logo.bi.bi-person-circle(aria-hidden="true")

        //- Menu dropdown (mantenha o restante do seu código de dropdown aqui)
        #profileDropdown.profile-dropdown(role="menu")
            a.dropdown-item(href="/perfil" role="menuitem")
              i.bi.bi-person(aria-hidden="true")
              |   Meu Perfil

            a.dropdown-item(href="#configuracoes" role="menuitem")
              i.bi.bi-gear(aria-hidden="true")
              |   Configurações

            a#minhasAudiodescricoes.dropdown-item(href="#minhas-audiodescricoes" style="display: none;" role="menuitem")
              i.bi.bi-headphones(aria-hidden="true")
              |   Minhas Audiodescrições

            a#meusMateriais.dropdown-item(href="#meus-materiais" style="display: none;" role="menuitem")
              i.bi.bi-file-earmark(aria-hidden="true")
              |   Meus Materiais

            a#adminPainel.dropdown-item(href="/painelAdmin1" onclick="irParaPainelAdmin(event)" role="menuitem")
              i.bi.bi-shield-lock(aria-hidden="true")
              |   Painel do Administrador

            hr.dropdown-divider

            a#logoutBtn.dropdown-item.logout(href="#sair")
              i.bi.bi-box-arrow-right(aria-hidden="true")
              |   Sair


//- MENU SECUNDÁRIO
section.sub-menu
  nav(aria-label="Menu de Páginas")
    a(href="/deficiencia-visual") Deficiência visual
    a(href="/audiodescricao") Audiodescrição
    a(href="/entretenimento") Entretenimento
    a(href="/forum") Fórum
    a(href="/biblioteca") Biblioteca
