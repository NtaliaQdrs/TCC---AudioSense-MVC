doctype html
html(lang="pt-br")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Cadastro de Docente 
    link(rel="stylesheet" href="../stylesheets/loginEcadastro.css")
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" )
  
  body
    main.container(role="main")
      .saudacao
        img.logo(src="../images/audiosense-login.png", alt="")
        h1 Bem vindo(a) ao AudioSense!
      
      .cad
        form(aria-label="Formulário de Cadastro de Docente")
          .input-group
            i.bi.bi-envelope-fill(aria-hidden="true")
            .input-content
              label(for="nome") Nome completo
              input#nome(type="text" placeholder="Nome completo aqui" required aria-required="true")
          
          .input-group
            i.bi.bi-envelope-fill(aria-hidden="true")
            .input-content
              label(for="email") Email institucional
              input#email(type="email" placeholder="Exemplo@gmail.com" required aria-required="true")
          
          .input-group
            i.bi.bi-key-fill(aria-hidden="true")
            .input-content
              label(for="senha") Crie uma senha
              input#senha(type="password" placeholder="••••••••••" required)
              button.btn-toggle-password(
                type="button" 
                onclick="togglePassword('senha')" 
                aria-label="Mostrar senha"
                style="background: none; border: none; cursor: pointer;"
              )
                i.bi.bi-eye.toggle-password(aria-hidden="true")
          
          .input-group
            i.bi.bi-key-fill(aria-hidden="true")
            .input-content
              label(for="confirmSenha") Confirme a senha
              input#confirmSenha(type="password" placeholder="••••••••••" required)
              button.btn-toggle-password(
                type="button" 
                onclick="togglePassword('confirmSenha')" 
                aria-label="Mostrar confirmação de senha"
                style="background: none; border: none; cursor: pointer;"
              )
                i.bi.bi-eye.toggle-password(aria-hidden="true")
          
          .input-group
            i.bi.bi-book-half(aria-hidden="true")
            .input-content
              label(for="disciplina") Disciplina(s) lecionada(s)
              select#disciplina(name="disciplina" required)
                option(value="") Selecione uma disciplina
                option(value="outra") Outra (digite abaixo)
              
              //- Campo dinâmico com rótulo acessível
              input#disciplinaOutra(
                type="text" 
                name="disciplinaOutra" 
                placeholder="Digite o nome da disciplina" 
                style="display: none; margin-top: 10px;"
                aria-label="Especifique a outra disciplina"
              )
          
          .input-group
            i.bi.bi-journal-text(aria-hidden="true")
            .input-content
              label(for="comprovante") Comprovante de vínculo
              input#comprovante(
                type="file" 
                required 
                aria-label="Anexar comprovante de vínculo (PDF ou Imagem)"
              )
          
          .input-group
            .input-content
              label(for="infoAdicional") Informações adicionais
              input#infoAdicional(type="text" placeholder="Alguma informação extra ou link...")
          
          .options
            label
              input(type="checkbox" style="accent-color: #2eb086;") 
              |  Me lembre
          
          button.btn-submit(type="submit") Cadastre-se
          
          p.footer-text
            | Já possui uma conta? 
            a(href="/login") Faça login

          p.footer-text
            a(href="/") Voltar para o início

script(src="../javascripts/cadastro.js")