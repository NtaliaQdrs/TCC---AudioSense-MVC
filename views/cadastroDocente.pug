doctype html
html(lang="pt-br")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Cadastro de Docente 
    link(rel="stylesheet" href="../stylesheets/loginEcadastro.css")
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" )
  
  body
    main.container(role="main")
      .saudacao
        img.logo(src="../images/audiosense-login.png", alt="")
        h1 Bem vindo(a) ao AudioSense!
      
      .cad
        form(action="/usuario/cadastro-docente" method="POST" enctype="multipart/form-data" aria-label="Formulário de Cadastro de Docente")
          .input-group
            i.bi.bi-person-fill(aria-hidden="true")
            .input-content
              label(for="nome_completo") Nome completo
              input#nome_completo(type="text" name="nome_completo" placeholder="Nome completo aqui" required aria-required="true")
          
          .input-group
            i.bi.bi-envelope-fill(aria-hidden="true")
            .input-content
              label(for="email") Email institucional
              input#email(type="email" name="email" placeholder="Exemplo@gmail.com" required aria-required="true")
          
          .input-group
            i.bi.bi-key-fill(aria-hidden="true")
            .input-content
              label(for="senha") Crie uma senha
              input#senha(type="password" name="senha" placeholder="••••••••••" required)
              button.btn-toggle-password(type="button" onclick="togglePassword('senha')" aria-label="Mostrar senha" style="background: none; border: none; cursor: pointer;")
                i.bi.bi-eye.toggle-password(aria-hidden="true")
          
          .input-group
            i.bi.bi-key-fill(aria-hidden="true")
            .input-content
              label(for="confirmSenha") Confirme a senha
              input#confirmSenha(type="password" name="confirmSenha" placeholder="••••••••••" required)
              button.btn-toggle-password(type="button" onclick="togglePassword('confirmSenha')" aria-label="Mostrar confirmação de senha" style="background: none; border: none; cursor: pointer;")
                i.bi.bi-eye.toggle-password(aria-hidden="true")
          
          .input-group
            i.bi.bi-book-half(aria-hidden="true")
            .input-content
              label(for="disciplina_id") Disciplina(s) lecionada(s)
              select#disciplina_id(name="disciplina_id" required)
                option(value="") Selecione uma disciplina
                each disciplina in disciplinas
                  option(value=disciplina.id)= disciplina.titulo
              input#disciplinaOutra(
                type="text"
                name="disciplina_outra"
                placeholder="Digite o nome da disciplina"
                style="display: none; margin-top: 10px;"
                aria-label="Especifique a outra disciplina"
              )
          
          .input-group
            i.bi.bi-journal-text(aria-hidden="true")
            .input-content
              label(for="comprovante") Comprovante de vínculo
              input#comprovante(type="file" name="comprovante" required aria-label="Anexar comprovante de vínculo (PDF ou Imagem)")
          
          .input-group
            .input-content
              label(for="informacao_adicional") Informações adicionais
              input#informacao_adicional(type="text" name="informacao_adicional" placeholder="Alguma informação extra ou link...")
          
          .options
            label
              input(type="checkbox" style="accent-color: #2eb086;") 
              |  Me lembre
          
          button.btn-submit(type="submit") Cadastre-se
          
          p.footer-text
            | Já possui uma conta? 
            a(href="/usuario") Faça login

          p.footer-text
            a(href="/") Voltar para o início

script(src="../javascripts/cadastro.js")
script.
  document.getElementById('disciplina_id').addEventListener('change', function() {
    const outraId = this.options[this.selectedIndex].text === 'Outra' ? true : false;
    const campoOutra = document.getElementById('disciplinaOutra');
    campoOutra.style.display = outraId ? 'block' : 'none';
    campoOutra.required = outraId;
  });