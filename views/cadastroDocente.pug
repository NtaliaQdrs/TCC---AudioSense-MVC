doctype html
html(lang="pt-br")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title cadastro_audiosense
    link(rel="stylesheet" href="../stylesheets/loginEcadastro.css")
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css")
  
  body
    .container
      .saudacao
        // Logo da AudioSense
        img.logo(src="../images/audiosense-login.png", alt="AudioSense Logo")
        h1 Bem vindo(a) ao AudioSense!
      
      .cad
        form
          .input-group
            i.bi.bi-envelope-fill
            .input-content
              label Nome completo
              input(type="text" placeholder="Nome completo aqui" required)
          
          .input-group
            i.bi.bi-envelope-fill
            .input-content
              label Email institucional
              input(type="email" placeholder="Exemplo@gmail.com" required)
          
          // Crie uma senha
          .input-group
            i.bi.bi-key-fill
            .input-content
              label Crie uma senha
              input#senha(type="password" placeholder="••••••••••")
              i.bi.bi-eye.toggle-password(onclick="togglePassword('senha')")
          
          // Confirme a senha
          .input-group
            i.bi.bi-key-fill
            .input-content
              label Confirme a senha
              input#confirmSenha(type="password" placeholder="••••••••••")
              i.bi.bi-eye.toggle-password(onclick="togglePassword('confirmSenha')")
          
          .input-group
            i.bi.bi-book-half
            .input-content
              label Disciplina(s) lecionada(s)
              select#disciplina(name="disciplina")
                option(value="") Selecione uma disciplina
                option(value="outra") Outra (digite abaixo)
              
              // Input que aparece só quando seleciona "Outra"
              input#disciplinaOutra(type="text" name="disciplinaOutra" placeholder="Digite a disciplina" style="display: none; margin-top: 10px;")
          
          .input-group
            i.bi.bi-journal-text
            .input-content
              label Comprovante de vínculo
              input(type="file")
          
          .input-group
            .input-content
              label Informações adicionais
              input(type="text" placeholder="Alguma informação extra ou link...")
          
          .options
            label
              input(type="checkbox" style="accent-color: #2eb086;") 
              |  Me lembre
          
          button.btn-submit(type="submit") Cadastre-se
          p.footer-text
            | Já possui uma conta? 
            a(href="/login") Faça login

          p.footer-text
            a(href="/") Voltar para o início

            
