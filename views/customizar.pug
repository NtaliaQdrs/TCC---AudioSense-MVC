doctype html
html(lang="pt-br")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title customizar_audiosense
    link(rel="stylesheet", href="../stylesheets/customizar.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css")

  body
    .containercust
      .saudacao
        img.logo(src="../images/audiosense-login.png" alt="AudioSense Logo")
        h1 Customizar perfil

      .content-wrapper
        .image-card
          img#preview(src="../images/foto-perfil-default.png" alt="Foto do usuário")
          label.btn-foto(for="foto-upload")
            i.bi.bi-pencil
            | Escolha uma foto

        form.form-area(action="/usuario/customizar" method="POST" enctype="multipart/form-data" aria-label="Formulário de Customização de Perfil")
          input#foto-upload(type="file" name="foto" accept="image/*" hidden)
          
          .input-group
            i.bi.bi-person-fill
            .input-content
              label(for="nome_usuario") Nome de usuário
              input#nome_usuario(type="text" name="nome_usuario" placeholder="Usuário123" required)

          .input-group
            i.bi.bi-card-text
            .input-content
              label(for="biografia") Biografia/Descrição
              textarea#biografia(
                name="biografia"
                placeholder="Digite aqui uma pequena descrição do seu perfil ou uma biografia..."
                rows="5"
              )

          .btn-group
            button.btn-submitcust(type="submit") Salvar
            button#btn-cancel.btn-cancel(type="reset") Cancelar

          p.footer-text
            | Já possui uma conta? 
            a(href="/usuario") Entre
    script(src="../javascripts/customizar.js")