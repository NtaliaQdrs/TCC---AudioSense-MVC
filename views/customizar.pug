doctype html
html(lang="pt-br")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title customizar_audiosense

    link(rel="stylesheet", href="../stylesheets/customizar.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css")

  body
    .containercust
      .saudacao
        img.logo(src="../images/audiosense-login.png" alt="AudioSense Logo")
        h1 Customizar perfil

      .content-wrapper
        .image-card
          // IMAGEM PADRÃO
          img#preview(src="default-user.png", alt="Foto do usuário")

          label.btn-foto(for="foto-upload") Escolha uma foto
          input#foto-upload(type="file", accept="image/*", hidden)

        .form-area
          .cad
            form
              .input-group
                i.bi.bi-person-fill
                .input-content
                  label Nome de usuário
                  input(type="text", placeholder="Usuário123", required)

              .input-group
                i.bi.bi-card-text
                .input-content
                  label Biografia/Descrição
                  textarea(
                    placeholder="Digite aqui uma pequena descrição do seu perfil ou uma biografia..."
                    rows="5"
                    required
                  )

              .btn-group
                button.btn-submitcust(type="submit") Salvar
                button.btn-cancel(type="button") Cancelar

              p.footer-text
                | Já possui uma conta? 
                a(href="/login") Entre

    script(src="../scripts/customizar.js")