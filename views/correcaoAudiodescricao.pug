extends layout

block styles
  link(rel='stylesheet', href='/stylesheets/audiodescricao.css')
  link(rel='stylesheet', href='/stylesheets/inserirAudiodescricao.css')

block content
  main.page
    h1.title Correção Audiodescrição

    section.container-form
      h2.form-title Avaliação de Roteiro de Audiodescrição

      .form-group
        label Enviado por
        p.form-control(style="background:#f0fdf4")= projeto.UsuarioDiscente.Usuario.nome_completo

      .form-group
        label Título
        p.form-control(style="background:#f0fdf4")= projeto.titulo

      .form-group
        label Descrição
        p.form-control(style="background:#f0fdf4")= projeto.descricao

      .form-group
        label Roteiro Original do Aluno
        textarea.form-control.textarea-large(readonly)= projeto.roteiro_texto

      form(action=`/corrigir-audiodescricao/${projeto.id}` method="POST")
        .form-group
          label(for="feedback") Feedback e Correções
          textarea#feedback.form-control.textarea-large(name="feedback" placeholder="Escreva aqui suas observações...")

        .form-group
          label(for="status") Decisão
          select#status.form-control(name="status")
            option(value="aprovado") ✅ Aprovar
            option(value="requer_ajustes") ✏️ Requer ajustes

        .button-group
          button.btn-submit(type="submit") Enviar correção
          a.btn-cancel(href="/audiodescricao") Cancelar