extends layout

block styles
  link(rel='stylesheet', href='/stylesheets/inserirAudiodescricao.css')

block content
  main.page
    h1.title Enviar Áudio Final

    section.container-form
      h2.form-title Envie o áudio da sua audiodescrição

      .form-group
        label Título
        p.form-control(style="background:#f0fdf4; margin:0")= projeto.titulo

      form(action=`/enviar-audio/${projeto.id}` method="POST" enctype="multipart/form-data")
        .form-group
          label Arquivo de áudio
          .upload-area(onclick="document.getElementById('audio').click()")
            img.upload-icon(src="/images/upload-icon.png" alt="Upload")
            .upload-text
              p Clique para selecionar o arquivo de áudio
              p(style="font-size:14px; color:#999") Formatos aceitos: MP3, WAV, OGG
            button.btn-upload(type="button") Selecionar arquivo
          input#audio(type="file" name="audio" accept="audio/*" hidden required)
          p#nome-arquivo(style="margin-top:10px; color:#2eb086; font-weight:600; display:none")

        .button-group
          button.btn-submit(type="submit") Enviar áudio
          a.btn-cancel(href="/audiodescricao") Cancelar

  script.
    document.getElementById('audio').addEventListener('change', function(e) {
      const file = e.target.files[0];
      if (!file) return;
      const label = document.getElementById('nome-arquivo');
      label.textContent = '✅ ' + file.name;
      label.style.display = 'block';
    });