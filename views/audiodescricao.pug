extends layout

block styles
  link(rel='stylesheet', href='/stylesheets/audiodescricao.css')

block content

  main.page
    h1.title Introdução a audiodescrição

    section.cards-extra
      .main-grid

        article.extra-card1.card1
          img(src="../images/definicao.png")
          h3 Definição e conceitos
          a(href="/") Ler mais

        article.extra-card.card2
          img(src="../images/usuarios.png")
          h3 Quem são os usuários da audiodescrição?
          a(href="/") Ler mais

        article.extra-card.card3
          img(src="../images/importancia.png")
          h3 A importância deste recurso
          a(href="/") Ler mais

        article.extra-card1.card4
          img(src="../images/exemplos.png")
          h3 Exemplos práticos
          a(href="/") Ler mais

        // SIDEBAR
                // SIDEBAR CORRIGIDA
        aside.sidebar(aria-labelledby="sidebar-title")
          h3#sidebar-title Sugestão de conteúdo adicional

          nav(aria-label="Links complementares")
            ul(style="list-style: none; padding: 0;")
              li
                .sidebar-item
                  i.bi.bi-file-earmark-text(aria-hidden="true")
                  small.text Artigos
                a(href="#") (Links para leitura)
              hr

              li
                .sidebar-item
                  i.bi.bi-play-btn(aria-hidden="true")
                  small.text Vídeos educacionais
                a(href="#") (Links de vídeos)
              hr

              li
                .sidebar-item
                  i.bi.bi-people(aria-hidden="true")
                  small.text Relatos
                a(href="#") (Depoimentos)

              hr

          // O botão agora está DENTRO da sidebar
          button.toggle-sidebar(
            onclick="toggleSidebar()"
            aria-expanded="true"
            aria-label="Expandir ou recolher menu"
          ) ↑

            

    .practice
      h2 Coloque em prática o que você aprendeu!
      br
      p Teste aqui o que você aprendeu sobre audiodescrição. Escolha uma imagem ou um pequeno vídeo e tente descrevê-lo, transmitindo todas as informações visuais.
      a(href="/#") Inserir audiodescrição

  script.
    function toggleSidebar() {
      const sidebar = document.querySelector('.sidebar');
      const button = document.querySelector('.toggle-sidebar');

      const isCollapsed = sidebar.classList.toggle('collapsed');

      button.textContent = isCollapsed ? '↓' : '↑';
      button.setAttribute('aria-expanded', !isCollapsed);
    }