extends layout

block styles
  link(rel='stylesheet' href='/stylesheets/perfil.css')

block content
  .perfil-container
    //- CABEÇALHO DO PERFIL
    .perfil-header
      .perfil-header-content
        .perfil-avatar-section
          .perfil-avatar
            img(src= usuario.foto_perfil ? '/uploads/fotos-perfil/' + usuario.foto_perfil : '/images/foto-perfil-default.png' alt="Avatar do usuário")
          button.avatar-upload-btn(aria-label="Alterar foto de perfil")
            i.bi.bi-camera-fill(aria-hidden="true")

        .perfil-info
          .perfil-info-header
            h1.perfil-name= usuario.nome_completo
            p.perfil-username= '@' + usuario.nome_usuario
          
          p.perfil-bio= usuario.biografia || 'Nenhuma biografia cadastrada.'
          if usuario.tipo_usuario === 'docente' && disciplinas.length > 0
            .perfil-disciplinas
              each disciplina in disciplinas
                span.disciplina-tag= disciplina.titulo

          .perfil-details
            .perfil-detail-item
              i.bi.bi-envelope-fill(aria-hidden="true")
              span= usuario.email

            .perfil-detail-item
              i.bi.bi-calendar-event(aria-hidden="true")
              span= 'Membro desde: ' + membroDesde

        .perfil-actions
          button.btn-editar-perfil(aria-label="Editar perfil")
            i.bi.bi-pencil(aria-hidden="true")
            span Editar perfil

    //- ESTATÍSTICAS
    .perfil-stats
      if usuario.tipo_usuario === 'docente'
        .stat-card
          .stat-icon
            i.bi.bi-volume-up(aria-hidden="true")
          .stat-content
            .stat-number 0
            .stat-label Audiodescrições corrigidas
      else
        .stat-card
          .stat-icon
            i.bi.bi-volume-up(aria-hidden="true")
          .stat-content
            .stat-number 0
            .stat-label Audiodescrições criadas

      .stat-card
        .stat-icon
          i.bi.bi-chat-dots(aria-hidden="true")
        .stat-content
          .stat-number 0
          .stat-label Postagens no fórum

      if usuario.tipo_usuario === 'docente'
        .stat-card
          .stat-icon
            i.bi.bi-book(aria-hidden="true")
          .stat-content
            .stat-number 0
            .stat-label Materiais compartilhados

        .stat-card
          .stat-icon
            i.bi.bi-hand-thumbs-up(aria-hidden="true")
          .stat-content
            .stat-number 0
            .stat-label Curtidas recebidas

    //- ABAS DE CONTEÚDO
    .perfil-tabs
      .tabs-header
        if usuario.tipo_usuario === 'docente'
          button.tab-btn.active(data-tab="audiodescricoes" aria-selected="true")
            i.bi.bi-volume-up(aria-hidden="true")
            span Audiodescrições corrigidas
        else
          button.tab-btn.active(data-tab="audiodescricoes" aria-selected="true")
            i.bi.bi-volume-up(aria-hidden="true")
            span Audiodescrições

        button.tab-btn(data-tab="forum" aria-selected="false")
          i.bi.bi-chat-left-text(aria-hidden="true")
          span Fórum

        if usuario.tipo_usuario === 'docente'
          button.tab-btn(data-tab="materiais" aria-selected="false")
            i.bi.bi-file-earmark-pdf(aria-hidden="true")
            span Materiais

      //- TAB: AUDIODESCRIÇÕES
      .tab-content#tab-audiodescricoes.tab-pane.active(role="tabpanel" aria-labelledby="tab-btn-audiodescricoes")
        .audiodescricoes-list
          .audiodescricao-item
            .item-icon
              i.bi.bi-film(aria-hidden="true")
            .item-content
              h3.item-title Descrição de cena - Filme: Extraordinário
              p.item-description Descrição da cena do corredor da escola.
            .item-meta
              span.item-date
                i.bi.bi-calendar(aria-hidden="true")
                | 15/05/2025
              button.btn-ver Ver

          .audiodescricao-item
            .item-icon
              i.bi.bi-film(aria-hidden="true")
            .item-content
              h3.item-title Descrição de cena - Filme: Soul
              p.item-description Descrição da cena inicial no metrô.
            .item-meta
              span.item-date
                i.bi.bi-calendar(aria-hidden="true")
                | 02/05/2025
              button.btn-ver Ver

          .audiodescricao-item
            .item-icon
              i.bi.bi-film(aria-hidden="true")
            .item-content
              h3.item-title Descrição de cena - Série: The Good Doctor
              p.item-description Descrição da cena do diagnóstico.
            .item-meta
              span.item-date
                i.bi.bi-calendar(aria-hidden="true")
                | 20/04/2025
              button.btn-ver Ver

        .view-all-link
          a(href="#") Ver todas

      //- TAB: FÓRUM
      .tab-content#tab-forum.tab-pane(role="tabpanel" aria-labelledby="tab-btn-forum")
        .forum-list
          .forum-item
            .forum-icon
              i.bi.bi-chat-dots(aria-hidden="true")
            .forum-content
              h3.forum-title Como aplicar audiodescição em conteúdos educacionais?
              p.forum-description Discussão sobre boas práticas e exemplos.
              .forum-meta
                span.forum-replies
                  i.bi.bi-chat-left(aria-hidden="true")
                  | 10 respostas
                span.forum-date
                  i.bi.bi-calendar(aria-hidden="true")
                  | 12/05/2025
                i.bi.bi-chevron-right(aria-hidden="true")

          .forum-item
            .forum-icon
              i.bi.bi-chat-dots(aria-hidden="true")
            .forum-content
              h3.forum-title Dúvida: descrição de gráficos e tabelas
              p.forum-description Alguém pode compartilhar técnicas?
              .forum-meta
                span.forum-replies
                  i.bi.bi-chat-left(aria-hidden="true")
                  | 7 respostas
                span.forum-date
                  i.bi.bi-calendar(aria-hidden="true")
                  | 05/05/2025
                i.bi.bi-chevron-right(aria-hidden="true")

          .forum-item
            .forum-icon
              i.bi.bi-chat-dots(aria-hidden="true")
            .forum-content
              h3.forum-title Indicação de ferramentas gratuitas
              p.forum-description Quais ferramentas vocês usam para gravar áudios?
              .forum-meta
                span.forum-replies
                  i.bi.bi-chat-left(aria-hidden="true")
                  | 15 respostas
                span.forum-date
                  i.bi.bi-calendar(aria-hidden="true")
                  | 28/04/2025
                i.bi.bi-chevron-right(aria-hidden="true")

        .view-all-link
          a(href="#") Ver todas

      //- TAB: MATERIAIS
      .tab-content#tab-materiais.tab-pane(role="tabpanel" aria-labelledby="tab-btn-materiais")
        .materiais-list
          .material-item
            .material-icon
              i.bi.bi-file-earmark-pdf(aria-hidden="true")
            .material-content
              h3.material-title Guia prático de audiodescição
              p.material-info PDF • 2.4 MB
            .material-action
              button.btn-download(aria-label="Baixar Guia prático de audiodescição")
                i.bi.bi-download(aria-hidden="true")

          .material-item
            .material-icon
              i.bi.bi-file-earmark-pdf(aria-hidden="true")
            .material-content
              h3.material-title Exemplos de roteiros de audiodescição
              p.material-info PDF • 1.8 MB
            .material-action
              button.btn-download(aria-label="Baixar Exemplos de roteiros de audiodescição")
                i.bi.bi-download(aria-hidden="true")

          .material-item
            .material-icon
              i.bi.bi-play-circle(aria-hidden="true")
            .material-content
              h3.material-title Tutorial: como criar audiodescição
              p.material-info Vídeo • 15:30
            .material-action
              button.btn-download(aria-label="Baixar Tutorial: como criar audiodescição")
                i.bi.bi-download(aria-hidden="true")

        .view-all-link
          a(href="#") Ver todas

  
  .modal-overlay#modalEditar(style="display:none")
    .modal-edicao
      .modal-header
        h3 Editar perfil
        button.btn-fechar-modal(type="button" onclick="fecharModalEditar()")
          i.bi.bi-x-lg

      form#formEditarPerfil(action="/usuario/editar-perfil" method="POST" enctype="multipart/form-data")
        .modal-body
          .modal-avatar-section
            img#previewAvatar(src='/images/foto-perfil-default.png' alt="Avatar")
            label.btn-foto(for="novaFoto")
              i.bi.bi-camera-fill
              | Alterar foto
            input#novaFoto(type="file" name="foto" accept="image/*" hidden)

          .modal-campos
            .input-group
              i.bi.bi-person-fill
              .input-content
                label(for="novo_nome_usuario") Nome de usuário
                input#novo_nome_usuario(type="text" name="nome_usuario" value=usuario.nome_usuario)
                if podeTrocarNome
                  small.hint Você pode trocar seu nome de usuário
                else
                  small.hint.bloqueado Disponível para troca em #{diasRestantes} dias

            .input-group
              i.bi.bi-card-text
              .input-content
                label(for="nova_biografia") Biografia
                textarea#nova_biografia(name="biografia" rows="3")= usuario.biografia || ''

        .modal-footer
          button.btn-cancel(type="button" onclick="fecharModalEditar()") Cancelar
          button.btn-submitcust(type="submit") Salvar
  script(src="/javascripts/perfil.js")
