extends layout

block styles
  link(rel="stylesheet", href="../stylesheets/index.css")

block content

  // ===== SEU CÓDIGO ORIGINAL (NÃO ALTERADO) =====

  section.welcome-section
    .welcome-container
      .welcome-content
        h1.welcome-title Boas vindas ao AudioSense!
        p.welcome-description
          | O AudioSense é um espaço que promove o aprendizado de audiodescrição e 
          | acessibilidade, contando com um espaço colaborativo, onde você poderá interagir 
          | com outros usuários.
        a.welcome-button#welcomeAuthBtn(href="/login") Entre ou Cadastre-se

      .welcome-icon
        img(src="../images/boasvindas.png" alt="Ilustração de boas-vindas: duas pessoas colaborando")

  section.stats-section
    .stats-container
      .stat-card
        .stat-icon
          i.bi.bi-people-fill
        h3.stat-title Usuários da plataforma
        p.stat-value
          span#total-discentes 0
          |  Discentes
          br
          span#total-docentes 0
          |  Docentes

      .stat-card
        .stat-icon
          i.bi.bi-images
        h3.stat-title Conteúdo audiovisual
        p.stat-value
          span#total-audiovisual 0
          |  Obras recomendadas

      .stat-card
        .stat-icon
          i.bi.bi-journal-richtext
        h3.stat-title Materiais educacionais
        p.stat-value
          span#total-materiais 0
          |  Materiais disponíveis

  // ===== NOVAS SEÇÕES (SEM IMPACTAR SEU CSS ATUAL) =====

  //- O que você vai aprender
  section.learning-extra
    .learning-extra-container
      h2 O que você vai aprender?

      .learning-item1 1. Compreender a deficiência visual
      .learning-item2 2. Princípios da audiodescrição
      .learning-item3 3. Entretenimento e educação acessíveis

  //- Cards adicionais
  section.cards-extra
    .cards-extra-container

      .extra-card
        i.bi.bi-eye-slash
        h3 Entendendo a deficiência visual
        p Saiba mais sobre as deficiências visuais e como interagir, tornando os espaços acessiveis.
        a(href="/cursos/deficiencia") Acessar

      .extra-card
        i.bi.bi-volume-up-fill
        h3 Introdução à audiodescrição
        p Aprenda o que é audiodescrição, como é aplicada e as praticas para produzir conteudos com acessibilidade.
        a(href="/cursos/audiodescricao") Acessar

      .extra-card
        i.
        h3 Entretenimento com acessibilidade
        p Conheça exemplos de filmes, series e outras formas de entretenimento que utilizam recursos com acessibilidade.
        a(href="/cursos/entretenimento") Acessar

  //- Espaço colaborativo
  section.collab-extra
  .collab-extra-container
    h2 Espaço colaborativo

    .collab-wrapper
      .collab-box
        i.bi.bi-book
        h3 Biblioteca de materiais
        p Encontre artigos, vídeos, apostilas e muito mais.
        a(href="/biblioteca") Acessar

      .collab-box
        i.bi.bi-chat-right-text
        h3 Fórum
        p Interaja com outros usuários.
        a(href="/forum") Acessar

  // ===== SCRIPT ORIGINAL =====
  script(src="../javascripts/index.js")