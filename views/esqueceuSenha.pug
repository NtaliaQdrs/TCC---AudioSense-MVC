doctype html
html(lang="pt-br")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Esqueceu a senha - AudioSense
    link(rel="stylesheet" href="../stylesheets/loginEcadastro.css")
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css")

  body
    main.container(role="main")
      .saudacao
        img.logo(src="../images/audiosense-login.png" alt="")
        h1 Redefinir senha

      if mensagem
        .alert-pendente
          i.bi.bi-check-circle-fill
          | #{mensagem}

      if erro
        .alert-rejeitado
          i.bi.bi-x-circle-fill
          | #{erro}

      if !mensagem
        p.footer-text Digite seu email cadastrado e enviaremos um link para redefinir sua senha.

        form(action="/usuario/esqueceu-senha" method="POST")
          .input-group
            i.bi.bi-envelope-fill(aria-hidden="true")
            .input-content
              label(for="email") Email
              input#email(type="email" name="email" placeholder="exemplo@gmail.com" required)

          button.btn-submit(type="submit") Enviar link

      p.footer-text
        a(href="/usuario") Voltar para o login