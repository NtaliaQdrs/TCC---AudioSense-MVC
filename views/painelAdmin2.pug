extends layout

block styles
  link(rel='stylesheet', href='/stylesheets/painelAdmin2.css')

block content
  .admin-panel-container
    .admin-header-banner
      h1 AudioSense Painel Administrativo - Moderação

    //- Seção: Cadastros Pendentes
    section.admin-section
      .section-title-group
        p.section-subtitle CADASTROS PENDENTES
        h2.section-title Cadastros de Docentes Pendentes
        p.section-description Usuários que estão se cadastrando como docentes e aguardam aprovação

      .filter-bar
        .search-input-wrapper
          i.bi.bi-search
          input.search-input(type="text" placeholder="Pesquisar docente...")
        select.filter-select
          option(value="") Filtrar por Status
          option(value="pendente") Pendente
          option(value="aprovado") Aprovado
          option(value="rejeitado") Rejeitado

      .user-list
        if docentesPendentes.length === 0
          p.section-description Nenhum cadastro pendente no momento.
        else
          each docente in docentesPendentes
            .user-card
              .user-avatar= docente.nome_completo.split(' ').map(n => n[0]).join('').slice(0, 2).toUpperCase()
              .user-info
                p.user-name= docente.nome_completo
                p.user-email= docente.email
                span.user-tag= docente.disciplina || 'Sem disciplina'
              span.status-badge= docente.status_aprovacao
              .action-buttons
                if docente.comprovante_vinculo
                  a.btn-action.btn-view(href=`/uploads/comprovantes/${docente.comprovante_vinculo}` target="_blank")
                    i.bi.bi-file-earmark-text
                    | Ver Documentos
                form(action=`/painelAdmin1/aprovar/${docente.docente_id}` method="POST" style="display:inline")
                  button.btn-action.btn-approve(type="submit")
                    i.bi.bi-check-lg
                    | Aprovar
                button.btn-action.btn-reject(type="button" onclick=`abrirModal('docente', '${docente.docente_id}')`)
                  i.bi.bi-x-lg
                  | Rejeitar

    //- Seção: Solicitações de Admin
    section.admin-section
      .section-title-group
        p.section-subtitle SOLICITAÇÕES DE ADMIN
        h2.section-title Solicitações para Acesso de Administrador
        p.section-description Docentes aprovados que solicitam acesso de administrador

      .filter-bar
        .search-input-wrapper
          i.bi.bi-search
          input.search-input(type="text" placeholder="Pesquisar docente...")
        select.filter-select
          option(value="") Filtrar por Status
          option(value="pendente") Pendente
          option(value="aprovado") Aprovado
          option(value="rejeitado") Rejeitado

      .user-list
        if !solicitacoesAdmin || solicitacoesAdmin.length === 0
          p.section-description Nenhuma solicitação pendente no momento.
        else
          each sol in solicitacoesAdmin
            .user-card
              .user-avatar= sol.nome_completo.split(' ').map(n => n[0]).join('').slice(0, 2).toUpperCase()
              .user-info
                p.user-name= sol.nome_completo
                p.user-email= sol.email
                .tags-row
                  span.user-tag.tag-docente Docente Aprovado
                  span.user-tag.tag-pendente Pendente
                p.user-description= sol.justificativa
              .action-buttons
                form(action=`/painelAdmin1/aprovar-admin/${sol.solicitacao_id}` method="POST" style="display:inline")
                  button.btn-action.btn-approve(type="submit")
                    i.bi.bi-check-lg
                    | Aprovar
                button.btn-action.btn-reject(type="button" onclick=`abrirModal('admin', '${sol.solicitacao_id}')`)
                  i.bi.bi-x-lg
                  | Rejeitar

  //- Modal de rejeição
  .modal-overlay#modalRejeitar(style="display:none")
    .modal-box
      h3 Motivo da rejeição
      textarea#motivoRejeicao(rows="4" placeholder="Explique o motivo da rejeição..." required)
      .modal-buttons
        button.btn-action.btn-approve(onclick="confirmarRejeicao()") Confirmar
        button.btn-action.btn-reject(onclick="fecharModal()") Cancelar
      form#formRejeitar(method="POST" style="display:none")
        input(type="hidden" name="motivo_rejeicao" id="inputMotivo")

  script.
    let urlRejeitar = '';

    function abrirModal(tipo, id) {
      if (tipo === 'docente') {
        urlRejeitar = `/painelAdmin1/rejeitar/${id}`;
      } else {
        urlRejeitar = `/painelAdmin1/rejeitar-admin/${id}`;
      }
      document.getElementById('motivoRejeicao').value = '';
      document.getElementById('modalRejeitar').style.display = 'flex';
    }

    function fecharModal() {
      document.getElementById('modalRejeitar').style.display = 'none';
    }

    function confirmarRejeicao() {
      const motivo = document.getElementById('motivoRejeicao').value.trim();
      if (!motivo) {
        alert('Por favor, informe o motivo da rejeição.');
        return;
      }
      const form = document.getElementById('formRejeitar');
      form.action = urlRejeitar;
      document.getElementById('inputMotivo').value = motivo;
      form.style.display = 'block';
      form.submit();
    }

    document.getElementById('modalRejeitar').addEventListener('click', function(e) {
      if (e.target === this) fecharModal();
    });