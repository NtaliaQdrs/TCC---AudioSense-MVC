extends layout

block styles
  link(rel="stylesheet" href="../stylesheets/painel.css")

block content
  
  main.containerad(role="main")
    .saudacao
      h1#titulo-pagina
        i.bi.bi-person-fill-lock(aria-hidden="true")
        |  Solicitar acesso de Administrador
    if mensagem
      .alert-success
        i.bi.bi-check-circle-fill
        | #{mensagem}

    p.instrucoes-admin O acesso de administrador fornece controle total sobre a gestão de usuários, conteúdo, configurações do sistema e relatórios. Esta função é reservada para pessoas autorizadas e requer aprovação.


    .divider

    .cad
      if mensagem
        .alert-success
          i.bi.bi-check-circle-fill
          | #{mensagem}

      else if solicitacaoPendente
        .alert-success
          i.bi.bi-clock-fill
          | Solicitação pendente, aguarde a aprovação do administrador.

      else
        form(action="/painelAdmin1/solicitar-admin" method="POST" aria-labelledby="titulo-pagina")
          .input-group
            .input-content
              label(for="justificativa") Justificativa
              textarea(
                id="justificativa"
                name="justificativa"
                placeholder="Por favor explique por que você precisa de acesso administrativo e quais funções você desempenhará. Seja específico e detalhado."
                rows="5"
                required
                aria-required="true"
              )

          .button-group
            button.btn-cancel(type="button" aria-label="Cancelar e voltar para a página anterior") Cancelar
            button.btn-submitcust(type="submit") Enviar solicitação

  script(src="/javascripts/index.js")
  script(src="/javascripts/menu.js")