doctype html
html(lang="pt-br")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title paineladmin_audiosense

    link(rel="stylesheet" href="../stylesheets/painel.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css")

  body
    .containerad
      .saudacao
        h1
          i.bi.bi-person-fill-lock
          |  Solicitar acesso de Administrador

      h1 O acesso de administrador fornece controle total sobre a gestão de usuários, conteúdo, configurações do sistema e relatórios. Esta função é reservada para pessoas autorizadas e requer aprovação.

      button.btn-submitcust(type="submit") solicitação pendente

      .divider
        span ou

      .cad
        form
          .input-group
            .input-content
              label Justificativa
              textarea(
                placeholder="Por favor explique por que você precisa de acesso administrativo e quais funções você desempenhará. Seja específico e detalhado."
                rows="5"
                required
              )

          .input-group
            .input-content
              label Documento de comprovação
              input(type="file")

          button.btn-cancel(type="button") Cancelar
          button.btn-submitcust(type="submit") Enviar solicitação

    script(src="../scripts/index.js")
    script(src="../scripts/admin.js")