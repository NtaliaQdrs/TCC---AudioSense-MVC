doctype html
html(lang="pt-br")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    link(rel="icon" type="image/png" href="/images/boasvindas.png")
    title cadastro de discente
    link(rel="stylesheet" href="../stylesheets/loginEcadastro.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css")

  body
    main.container(role="main")
      .saudacao
        img.logo(src="../images/audiosense-login.png" alt="")
        h1 Bem vindo(a) ao AudioSense!

      .social-login
        a.btn-social(href="#" aria-label="Cadastrar-se usando sua conta do Google")
          img(src="https://www.google.com/favicon.ico", width="20", alt="")
          |  Login com Google
        a.btn-social(href="#" aria-label="Cadastrar-se usando sua conta do Facebook")
          img(src="https://www.facebook.com/favicon.ico", width="20", alt="")
          |  Login com Facebook

      .divider
        span ou

      .cad
        form(action="/usuario/cadastro-discente" method="POST" aria-label="Formulário de Cadastro de Discente")
          .input-group
            i.bi.bi-person-fill(aria-hidden="true")
            .input-content
              label(for="nome_completo") Nome completo
              input#nome_completo(type="text" name="nome_completo" placeholder="Nome completo aqui" required)

          .input-group
            i.bi.bi-envelope-fill(aria-hidden="true")
            .input-content
              label(for="email") Email
              input#email(type="email" name="email" placeholder="Exemplo@gmail.com" required)

          .input-group
            i.bi.bi-key-fill(aria-hidden="true")
            .input-content
              label(for="senha") Crie uma senha
              input#senha(type="password" name="senha" placeholder="••••••••••" required)
              button.btn-toggle-password(type="button" onclick="togglePassword('senha')" aria-label="Mostrar senha" style="background: none; border: none; cursor: pointer;")
              i.bi.bi-eye.toggle-password(aria-hidden="true" onclick="togglePassword('senha')")

          .input-group
            i.bi.bi-key-fill(aria-hidden="true")
            .input-content
              label(for="confirmSenha") Confirme a senha
              input#confirmSenha(type="password" name="confirmSenha" placeholder="••••••••••" required)
              button.btn-toggle-password(type="button" onclick="togglePassword('confirmSenha')" aria-label="Mostrar senha" style="background: none; border: none; cursor: pointer;")
              i.bi.bi-eye.toggle-password(aria-hidden="true" onclick="togglePassword('confirmSenha')")

          .options

          button.btn-submit(type="submit") Cadastre-se
          button#btn-cancel.btn-cancel(type="reset") Cancelar

          p.footer-text
            | Já possui uma conta? 
            a(href="/usuario") Faça login

          p.footer-text
            a(href="/") Voltar para o início


    script(src="../javascripts/cadastro.js")