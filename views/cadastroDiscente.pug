doctype html
html(lang="pt-br")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title cadastrodiscente_audiosense
    link(rel="stylesheet" href="../stylesheets/loginEcadastro.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css")

  body
    .container
      .saudacao
        img.logo(src="../images/audiosense-login.png" alt="AudioSense Logo")
        h1 Bem vindo(a) ao AudioSense!

      .social-login
        a.btn-social(href="#")
          img(src="https://www.google.com/favicon.ico", width="20", alt="Google")
          |  Login com Google
        a.btn-social(href="#")
          img(src="https://www.facebook.com/favicon.ico", width="20", alt="Facebook")
          |  Login com Facebook

      .divider
        span ou

      .cad
        form
          .input-group
            i.bi.bi-envelope-fill
            .input-content
              label Nome completo
              input(type="text", placeholder="Nome completo aqui", required)

          .input-group
            i.bi.bi-envelope-fill
            .input-content
              label Email
              input(type="email", placeholder="Exemplo@gmail.com", required)

          .input-group
            i.bi.bi-key-fill
            .input-content
              label Crie uma senha
              input#senha(type="password", placeholder="••••••••••")
              i.bi.bi-eye.toggle-password(onclick="togglePassword('senha')")

          .input-group
            i.bi.bi-key-fill
            .input-content
              label Confirme a senha
              input#confirmSenha(type="password", placeholder="••••••••••")
              i.bi.bi-eye.toggle-password(onclick="togglePassword('confirmSenha')")

          .options
            label
              input(type="checkbox", style="accent-color: #2eb086;")
              |  Me lembre

          button.btn-submit(type="submit") Cadastre-se
          p.footer-text
            | Já possui uma conta? 
            a(href="/login") Faça login

    script(src="../scripts/cadastro.js")