doctype html
html(lang="pt-br")
  head
    title= title
    meta(charset="UTF-8")
    link(rel="icon" type="image/png" href="/images/boasvindas.png")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    
    link(rel='stylesheet', href='/stylesheets/menu.css')
    block styles
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css")

  body
    //- Botão para acessibilidade (teclado)
    a.skip-link(href="#main-content") Pular para o conteúdo principal

    //- MENU PRINCIPAL
    header.top-bar
      .logo
        img(src="/images/audiosense.png" alt="AudioSense")

      //- Botão para categorias (visível apenas no mobile)
      button#categoryToggle.category-toggle(aria-label="Abrir categorias")
        i.bi.bi-grid-3x3-gap-fill

      //- Contêiner para as categorias do sub-menu (visível apenas no mobile)
      #categoryDropdown.category-dropdown
        .category-links
        a.dropdown-item(href="/") Início
          a.dropdown-item(href="/deficiencia-visual") Deficiência visual
          a.dropdown-item(href="/audiodescricao") Audiodescrição
          a.dropdown-item(href="/entretenimento") Entretenimento
          a.dropdown-item(href="/forum") Fórum
        a.dropdown-item(href="/biblioteca") Biblioteca

      nav.menu-links
        a(href="/") Início
        a(href="#") Configurações
        a(href="#") Sobre nós

      .menu-right
        .search-box
          i.bi.bi-search
          input(type="text" placeholder="Pesquise...")

        //- Perfil
        .profile-menu
          button#profileBtn.profile-button(aria-haspopup="true" aria-expanded="false")
            span Perfil 
            i#perfil-logo.bi.bi-person-circle

          //- Menu dropdown
          #profileDropdown.profile-dropdown
            a.dropdown-item(href="/perfil")
              i.bi.bi-person
              |   Meu Perfil

            a.dropdown-item(href="#configuracoes")
              i.bi.bi-gear
              |   Configurações

            a#minhasAudiodescricoes.dropdown-item(href="#minhas-audiodescricoes" style="display: none;")
              i.bi.bi-headphones
              |   Minhas Audiodescrições

            a#meusMateriais.dropdown-item(href="#meus-materiais" style="display: none;")
              i.bi.bi-file-earmark
              |   Meus Materiais

            a#adminPainel.dropdown-item(href="/painelAdmin1"  onclick="irParaPainelAdmin(event)")
              i.bi.bi-shield-lock
              |   Painel do Administrador

            hr.dropdown-divider

            a#logoutBtn.dropdown-item.logout(href="#sair")
              i.bi.bi-box-arrow-right
              |   Sair

    //- MENU SECUNDÁRIO
    section.sub-menu
      nav
        a(href="/deficiencia-visual") Deficiência visual
        a(href="/audiodescricao") Audiodescrição
        a(href="/entretenimento") Entretenimento
        a(href="/forum") Fórum
        a(href="/biblioteca") Biblioteca

    //- ÁREA DE CONTEÚDO PRINCIPAL
    main#main-content
      block content

    //- Script global
    script(src="/javascripts/menu.js")
