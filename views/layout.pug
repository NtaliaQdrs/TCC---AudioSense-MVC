doctype html
html(lang="pt-br")
  head
    title #{title}
    meta(charset="UTF-8")
    link(rel="icon" type="image/png" href="/images/boasvindas.png")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    link(rel='stylesheet' href='/stylesheets/menu.css')
    block styles
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css")

  body
    


    //- MENU PRINCIPAL
    header.top-bar
      .top-bar-content
        a.skip-link(href="#main-content") Pular para o conteúdo principal
        .logo
          a( aria-label="AudioSense - Página Inicial")
            img(src="/images/audiosense.png" alt="")

        //- Botão de categorias mobile com estado expandido
        button#categoryToggle.category-toggle(
          aria-label="Abrir menu de categorias" 
          aria-haspopup="true" 
          aria-expanded="false"
          aria-controls="categoryDropdown"
        )
          i.bi.bi-grid-3x3-gap-fill(aria-hidden="true")

        //- Contêiner para as categorias do sub-menu (visível apenas no mobile)
        #categoryDropdown.category-dropdown
          .category-links
            a.dropdown-item(href="/") Início
            a.dropdown-item(href="/configuracoes") Configurações
            a.dropdown-item(href="/deficiencia-visual") Deficiência visual
            a.dropdown-item(href="/audiodescricao") Audiodescrição
            a.dropdown-item(href="/entretenimento") Entretenimento
            a.dropdown-item(href="/forum") Fórum
            a.dropdown-item(href="/biblioteca") Biblioteca

        nav.menu-links(aria-label="Menu Principal")
          a(href="/") Início
          a(href="/configuracoes") Configurações
          a(href="#") Sobre nós

        .menu-right
          .search-box1
            i.bi.bi-search(aria-hidden="true")
            input(type="text" placeholder="Pesquise..." aria-label="Pesquisar conteúdo no AudioSense")

          //- Perfil
          .profile-menu
            button#profileBtn.profile-button(aria-haspopup="true" 
                                            aria-expanded="false" 
                                            aria-controls="profileDropdown" 
                                            aria-label="Menu do perfil do usuário")
              span Perfil 
              i#perfil-logo.bi.bi-person-circle(aria-hidden="true")
              span#badge-perfil.badge(style="display:none") 0


            //- Menu dropdown
            #profileDropdown.profile-dropdown(role="menu")
              
              //- ABAS (NOVO)
              .dropdown-tabs
                button.tab-btn.tab-active(data-tab="profile" aria-selected="true")
                  i.bi.bi-person-circle(aria-hidden="true")
                button.tab-btn(data-tab="notifications" aria-selected="false")
                  i.bi.bi-bell(aria-hidden="true")
                  span#badge-notificacoes.badge(style="display:none") 0

              //- ABA PERFIL
              .tab-pane.tab-pane-active#profile-tab
                a.dropdown-item(href="/usuario/perfil" role="menuitem")
                  i.bi.bi-person(aria-hidden="true")
                  |   Meu Perfil

                a.dropdown-item(href="/usuario/configuracoes-perfil" role="menuitem")
                  i.bi.bi-gear(aria-hidden="true")
                  |   Configurações

                a#minhasAudiodescricoes.dropdown-item(href="/usuario/minhas-audiodescricoes" style="display: none;" role="menuitem")
                  i.bi.bi-headphones(aria-hidden="true")
                  |   Minhas Audiodescrições

                a#meusMateriais.dropdown-item(href="/usuario/meus-materiais" style="display: none;" role="menuitem")
                  i.bi.bi-file-earmark(aria-hidden="true")
                  |   Meus Materiais

                a#adminPainel.dropdown-item(href="/painelAdmin1" onclick="irParaPainelAdmin(event)" role="menuitem")
                  i.bi.bi-shield-lock(aria-hidden="true")
                  |   Painel do Administrador

                hr.dropdown-divider

                a#logoutBtn.dropdown-item.logout(href="/usuario/logout")
                  i.bi.bi-box-arrow-right(aria-hidden="true")
                  |   Sair da conta

              //- ABA NOTIFICAÇÕES
              .tab-pane#notifications-tab
                p(style="padding: 15px; color: #666; font-size: 14px;") Carregando...

                hr.dropdown-divider

                a.dropdown-item(href="#" role="menuitem" style="text-align: center; font-size: 12px;")
                  |   Ver todas as notificações

    //- MENU SECUNDÁRIO
    section.sub-menu
      nav(aria-label="Menu de Páginas")
        a(href="/deficiencia-visual") Deficiência visual
        a(href="/audiodescricao") Audiodescrição
        a(href="/entretenimento") Entretenimento
        a(href="/forum") Fórum
        a(href="/biblioteca") Biblioteca

    //- ÁREA DE CONTEÚDO PRINCIPAL
    main#main-content(tabindex="-1")
      block content

    //- Script global
    script.
      const usuarioLogado = !{JSON.stringify(usuarioLogado)};
    script(src="/javascripts/menu.js")
    script(src="/javascripts/accessibility.js")
    
