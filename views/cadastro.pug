doctype html
html(lang="pt-br")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Escolher Perfil 
    
    //- Link para o arquivo CSS
    link(rel="stylesheet" href="../stylesheets/loginEcadastro.css")
    
    //- Ícones do Bootstrap
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css")

  body
    main.container(role="main")
      .saudacao
        //- Logo da AudioSense
        img.logo(src="../images/audiosense-login.png" alt="")
        h1 Bem vindo(a) ao AudioSense!
        h2#pergunta-perfil Antes de continuar, escolha seu tipo de usuário:

      //- Região de navegação para as opções de cadastro
      nav.buttons-container(aria-labelledby="pergunta-perfil")
        //- Botão Discente: aria-label explica a ação completa
        a.option-button.discente(
          href="/usuario/cadastro-discente" 
          role="button" 
          aria-label="Cadastrar-se como Discente (Estudante)"
        )
          //- Imagem decorativa (alt vazio) pois o texto já explica tudo
          img(src="../images/discente.png" width="20" alt="")
          span SOU DISCENTE

        //- Botão Docente: aria-describedby conecta ao aviso de homologação
        a.option-button.docente(
          href="/usuario/cadastro-docente" 
          role="button" 
          aria-label="Cadastrar-se como Docente (Professor)"
          aria-describedby="aviso-docente"
        )
          img(src="../images/docente.png" width="20" alt="")
          span SOU DOCENTE

      .warning#aviso-docente(role="note" aria-label="Aviso importante para docentes. caso o seu perfil seja do tipo DOCENTE, seus dados passarão por uma análise para sua conta ser homologada. ")
        p 
          strong *Lembre-se: 
          | caso o seu perfil seja do tipo DOCENTE, seus dados passarão por uma análise para sua conta ser homologada.
      .footer-links
        p.footer-text
          | Já possui uma conta? 
          a(href="/usuario") Faça login

        p.footer-text
          a(href="/") Voltar para o início

      
      br
      br
      