doctype html
html(lang="pt-br")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    link(rel="icon" type="image/png" href="/images/boasvindas.png")
    title Login
    link(rel="stylesheet" href="../stylesheets/loginEcadastro.css")
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css")

  body
    main.container(role="main")
      .saudacao
        img.logo(src="../images/audiosense-login.png" alt="")
        h1 Bem vindo(a) de volta ao AudioSense!

      if erro === 'email'
        .alert-rejeitado
          i.bi.bi-x-circle-fill
          | Este email já está cadastrado.

      if erro === 'disciplina'
        .alert-rejeitado
          i.bi.bi-x-circle-fill
          | Selecione pelo menos uma disciplina.
          
      if status === 'pendente'
        .alert-pendente
          i.bi.bi-clock-fill
          | Seu cadastro está aguardando aprovação do administrador.

      if status === 'rejeitado'
        .alert-rejeitado
          i.bi.bi-x-circle-fill
          | Seu cadastro foi rejeitado.
          if motivo
            p.motivo= motivo
          a(href=`/usuario/cadastro-docente?email=${email}`) Tentar novamente

      if status === 'senha_redefinida'
        .alert-pendente
          i.bi.bi-check-circle-fill
          | Senha redefinida com sucesso! Faça login com sua nova senha.

      .social-login
        a.btn-social(href="#" aria-label="Fazer login usando sua conta do Google")
          img(src="https://www.google.com/favicon.ico" width="20" alt="Google")
          |  Login com Google
        a.btn-social(href="#" aria-label="Fazer login usando sua conta do Facebook")
          img(src="https://www.facebook.com/favicon.ico" width="20" alt="Facebook")
          |  Login com Facebook

      .divider
        span ou

      form(action="/usuario/login" method="POST" aria-label="Formulário de Login")
        .input-group
          i.bi.bi-envelope-fill(aria-hidden="true")
          .input-content
            label(for="email") Email
            input#email(type="email" name="email" placeholder="exemplo@gmail.com" required aria-required="true")

        .input-group
          i.bi.bi-key-fill(aria-hidden="true")
          .input-content
            label(for="senha") Senha
            input#senha(type="password" name="senha" placeholder="••••••••••" required)
            button.btn-toggle-password(
              type="button"
              onclick="togglePassword('senha')"
              aria-label="Mostrar senha"
              style="background: none; border: none; cursor: pointer;"
            )
            i.bi.bi-eye.toggle-password(onclick="togglePassword('senha')")

        .options
          label
            input(type="checkbox" name="manterConectado" style="accent-color: #2eb086;")
            |  Manter conectado
          a(href="/usuario/esqueceu-senha" aria-label="Recuperar senha esquecida") Esqueceu a senha?

        button.btn-submit(type="submit") Entrar
        button#btn-cancel.btn-cancel(type="reset") Cancelar

      p.footer-text
        | Não possui uma conta?
        a(href="/usuario/cadastro")  Cadastre-se

      p.footer-text
        a(href="/") Voltar para o início

    script(src="../javascripts/login.js")
    